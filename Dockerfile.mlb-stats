FROM python:3.12-slim
WORKDIR /app

COPY backend/requirements.txt /tmp/requirements.txt
RUN grep -vE "sentence-transformers|xgboost|scikit-learn|torch|pyarrow|feedparser" /tmp/requirements.txt > /tmp/req-min.txt \
    && echo "httpx" >> /tmp/req-min.txt \
    && pip install --no-cache-dir -r /tmp/req-min.txt

COPY backend/ .
ENV PYTHONPATH=/app

CMD ["python", "-m", "app.ingestion.mlb_stats"]
